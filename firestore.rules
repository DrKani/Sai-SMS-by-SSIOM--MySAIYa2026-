rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny access by default (Least Privilege)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Check if the requesting user is an authorized admin by email
    // Helper: Check if the requesting user is an authorized admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('.*@ssiomya.com') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || resource.data.publicLeaderboard == true);
      allow list: if isAdmin();
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;

      // WordSearch game progress
      match /gameProgress/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Briefcase items
      match /briefcase/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Rollups (leaderboard data) ---
    match /rollups/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Metadata / National Stats ---
    match /metadata/national_stats {
      allow read: if true;
      allow update: if request.auth != null;
    }

    match /metadata/site_config {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /metadata/national_stats/participants/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Badge Events ---
    match /badge_events/{eventId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Journals ---
    match /journals/{journalId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // --- Sadhana Daily ---
    match /sadhanaDaily/{docId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin() || resource.data.publicLeaderboard == true);
      allow create: if request.auth != null 
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.uid == request.auth.uid;
    }

    // --- Announcements, Calendar & Book Club ---
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /calendar/{docId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
                    (request.auth != null &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredUsers', 'registeredCount']));
    }

    match /bookclubWeeks/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /bookClubProgress/{docId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /aggregates/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /aggregates_byCentre/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /aggregates_byState/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /aggregates_byUser/{docId} {
      allow read: if request.auth != null && (request.auth.uid == docId || isAdmin());
      allow write: if false;
    }

    // --- Reflections ---
    match /reflections/{docId} {
      allow read: if request.auth != null && (resource.data.status == 'approved' || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // --- Badges (subcollection of users) ---
    match /users/{userId}/badges/{badgeId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      // Clients may only mark isRead; creation is reserved for Cloud Functions (Admin SDK bypasses rules)
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // --- Articles ---
    match /articles/{articleId} {
      allow read: if (
        resource.data.status == 'published' ||
        (request.auth != null && (
          resource.data.authorUid == request.auth.uid ||
          isAdmin()
        ))
      );
      allow create: if isAdmin();
      allow update: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Article Comments ---
    match /articleComments/{commentId} {
      allow read: if resource.data.status == 'approved' ||
                  (request.auth != null && (resource.data.uid == request.auth.uid || isAdmin()));
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // --- Polls ---
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      // Admin manages; Cloud Functions update denormalised counts
      allow update: if isAdmin();
    }

    // --- Poll Responses ---
    match /pollResponses/{responseId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      // One response per user per poll; immutable after creation
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Contact Submissions ---
    match /contactSubmissions/{submissionId} {
      // Admins read all; submitter may read their own if authenticated
      allow read: if isAdmin() ||
                  (request.auth != null && resource.data.uid == request.auth.uid);
      // Public create — contact form is accessible before login
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
