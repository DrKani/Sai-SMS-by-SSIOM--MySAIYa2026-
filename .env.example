# ─────────────────────────────────────────────────────────────────────────────
# Sai SMS by SSIOM — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in your own values.
# NEVER commit your real .env file to git — it is already in .gitignore.
#
# How to find these values:
#   Firebase values → Firebase Console → Project Settings → Your Apps → Web App
#   Gemini API key  → https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

# Firebase configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Gemini AI (used for AI-assisted features)
GEMINI_API_KEY=your_gemini_api_key_here
